<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:BuhtaLink.Resources.Views"
       x:Class="BuhtaLink.AppShell">

    <!-- Страница логина (первая при запуске) -->
    <ShellContent Route="login"
                  ContentTemplate="{DataTemplate views:LoginPage}" />

    <!-- Страница регистрации -->
    <ShellContent Route="register"
                  ContentTemplate="{DataTemplate views:RegisterPage}" />

    <!-- Основные вкладки -->
    <TabBar Route="main">
        <Tab Title="Новости" Icon="news_icon.png">
            <ShellContent Route="news" ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>
        <Tab Title="Сообщения" Icon="msg_icon.png">
            <ShellContent Route="messages" ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>
        <Tab Title="Профиль" Icon="profile_icon.png">
            <ShellContent Route="profile" ContentTemplate="{DataTemplate views:ProfilePage}" />
        </Tab>
    </TabBar>
</Shell>