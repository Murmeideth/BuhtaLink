<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BuhtaLink.Resources.Views.RegisterPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#060330">

    <Grid VerticalOptions="Center" Padding="30">
        <VerticalStackLayout Spacing="15" MaximumWidthRequest="400">

            <!-- Заголовок -->
            <Label Text="Регистрация"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="Gainsboro"
                   Margin="0,0,0,20"/>

            <!-- Логин -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Логин"
                       TextColor="Gray"
                       FontSize="13"/>
                <Entry Placeholder="Придумайте логин"
                       Text="{Binding Username}"
                       PlaceholderColor="Gray"
                       TextColor="Gainsboro"
                       BackgroundColor="#474b4e"
                       FontSize="16"/>
            </VerticalStackLayout>

            <!-- Полное имя -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Полное имя"
                       TextColor="Gray"
                       FontSize="13"/>
                <Entry Placeholder="Иван Петров"
                       Text="{Binding FullName}"
                       PlaceholderColor="Gray"
                       TextColor="Gainsboro"
                       BackgroundColor="#474b4e"
                       FontSize="16"/>
            </VerticalStackLayout>

            <!-- Никнейм -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Никнейм"
                       TextColor="Gray"
                       FontSize="13"/>
                <Entry Placeholder="Как вас отображать"
                       Text="{Binding Nickname}"
                       PlaceholderColor="Gray"
                       TextColor="Gainsboro"
                       BackgroundColor="#474b4e"
                       FontSize="16"/>
            </VerticalStackLayout>

            <!-- Пароль -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Пароль"
                       TextColor="Gray"
                       FontSize="13"/>
                <Entry Placeholder="Придумайте пароль"
                       Text="{Binding Password}"
                       IsPassword="True"
                       PlaceholderColor="Gray"
                       TextColor="Gainsboro"
                       BackgroundColor="#474b4e"
                       FontSize="16"/>
            </VerticalStackLayout>

            <!-- Повтор пароля -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Повторите пароль"
                       TextColor="Gray"
                       FontSize="13"/>
                <Entry Placeholder="Повторите пароль"
                       Text="{Binding ConfirmPassword}"
                       IsPassword="True"
                       PlaceholderColor="Gray"
                       TextColor="Gainsboro"
                       BackgroundColor="#474b4e"
                       FontSize="16"/>
            </VerticalStackLayout>

            <!-- Кнопка регистрации -->
            <Button Text="Создать аккаунт"
                    Command="{Binding RegisterCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    BackgroundColor="#001e47"
                    TextColor="Gainsboro"
                    FontSize="18"
                    HeightRequest="50"
                    CornerRadius="25"
                    Margin="0,10,0,0"/>

            <!-- Ссылка на логин -->
            <HorizontalStackLayout HorizontalOptions="Center"
                                   Spacing="5">
                <Label Text="Уже есть аккаунт?"
                       TextColor="Gray"
                       FontSize="14"
                       VerticalOptions="Center"/>
                <Button Text="Войти"
                        Command="{Binding GoToLoginCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#4da6ff"
                        FontSize="14"
                        BorderWidth="0"
                        VerticalOptions="Center"
                        Padding="0"/>
            </HorizontalStackLayout>

            <!-- Индикатор загрузки -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="Gainsboro"/>

            <!-- Сообщение об ошибке -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="#ff6b6b"
                   HorizontalTextAlignment="Center"
                   FontSize="14"
                   IsVisible="{Binding HasError}">
                <Label.Triggers>
                    <DataTrigger TargetType="Label" 
                     Binding="{Binding HasError}" 
                     Value="False">
                        <Setter Property="Text" Value=""/>
                    </DataTrigger>
                </Label.Triggers>
            </Label>

        </VerticalStackLayout>
    </Grid>
</ContentPage>