<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BuhtaLink.Resources.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#060330">

    <Grid VerticalOptions="Center" Padding="30">
        <VerticalStackLayout Spacing="20" MaximumWidthRequest="400">

            <!-- Заголовок -->
            <Label Text="BuhtaLink"
                   FontSize="36"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="Gainsboro"
                   Margin="0,0,0,20"/>

            <!-- Поля ввода -->
            <Entry Placeholder="Логин"
                   Text="{Binding Username}"
                   PlaceholderColor="Gray"
                   TextColor="Gainsboro"
                   BackgroundColor="#474b4e"
                   FontSize="16"/>

            <Entry Placeholder="Пароль"
                   Text="{Binding Password}"
                   IsPassword="True"
                   PlaceholderColor="Gray"
                   TextColor="Gainsboro"
                   BackgroundColor="#474b4e"
                   FontSize="16"/>

            <!-- Кнопка входа -->
            <Button Text="Войти"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    BackgroundColor="#001e47"
                    TextColor="Gainsboro"
                    FontSize="18"
                    HeightRequest="50"
                    CornerRadius="25"/>

            <!-- Кнопка регистрации -->
            <Button Text="Зарегистрироваться"
                    Command="{Binding GoToRegisterCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    BackgroundColor="Transparent"
                    TextColor="Gainsboro"
                    FontSize="14"
                    BorderColor="Gray"
                    BorderWidth="1"/>

            <!-- Индикатор загрузки -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="Gainsboro"
                               Margin="0,10"/>

            <!-- Сообщение об ошибке -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="#ff6b6b"
                   HorizontalTextAlignment="Center"
                   FontSize="14"
                   IsVisible="{Binding HasError}"/>

        </VerticalStackLayout>
    </Grid>
</ContentPage>